# API locale
API_PORT=3000
LOCAL_WS_PATH=/stream

# Flux Deribit
DERIBIT_WS_URL=wss://www.deribit.com/ws/api/v2
DERIBIT_CHANNELS=ticker.BTC-PERPETUAL.100ms,ticker.ETH-PERPETUAL.100ms,ticker.SOL-PERPETUAL.100ms,deribit_price_index.btc_usd,deribit_price_index.eth_usd,deribit_price_index.sol_usd
HEARTBEAT_INTERVAL_SECONDS=10
RECONNECT_DELAY_MS=3000
SNAPSHOT_INTERVAL_MS=30000
MAX_EVENTS_IN_MEMORY=2000

# PostgreSQL / TimescaleDB (docker-compose)
DATABASE_URL=postgres://icare:icare@localhost:5432/icare
DB_SCHEMA=public
DB_TABLE=deribit_events
TIMESCALE_ENABLED=true
TS_CHUNK_INTERVAL=1 day
TS_RETENTION_INTERVAL=30 days
TS_AGG_BUCKET=1 minute
TS_AGG_POLICY_START_OFFSET=7 days
TS_AGG_POLICY_END_OFFSET=1 minute
TS_AGG_POLICY_SCHEDULE=1 minute
